---
const { lang = 'ro', altHref = '/en/' } = Astro.props;
const t = lang === 'ro'
  ? {
      platform: 'Platformă', solutions: 'Soluții', architecture: 'Arhitectură', news: 'Noutăți',
      demo: 'Programează un demo', langLabel: 'EN', theme: 'Comută tema',
      p1: 'Ansamblu', p2: 'ZenView · ZenPACS', p3: 'RIS & raportare', p4: 'Teleradiologie', p5: 'Portal pacient',
      s1: 'Clinici & lanțuri', s2: 'Spitale', s3: 'Rețele de teleradiologie',
      base: '',
    }
  : {
      platform: 'Platform', solutions: 'Solutions', architecture: 'Architecture', news: 'Updates',
      demo: 'Book a demo', langLabel: 'RO', theme: 'Toggle theme',
      p1: 'Overview', p2: 'ZenView · ZenPACS', p3: 'RIS & reporting', p4: 'Teleradiology', p5: 'Patient portal',
      s1: 'Clinics & chains', s2: 'Hospitals', s3: 'Teleradiology networks',
      base: '/en',
    };
const b = t.base;
---
<header class="site-header">
  <div class="wrap bar">
    <a class="logo" href={b + '/'} aria-label="ZenRIS — acasă">Zen<b>RIS</b></a>
    <nav class="nav" aria-label={lang === 'ro' ? 'Navigație principală' : 'Main navigation'}>
      <div class="drop">
        <button type="button" aria-expanded="false">{t.platform} <span aria-hidden="true">▾</span></button>
        <div class="menu">
          <a href={b + '/platforma/'}>{t.p1}</a>
          <a href={b + '/platforma/pacs-viewer/'}>{t.p2}</a>
          <a href={b + '/platforma/ris-raportare/'}>{t.p3}</a>
          <a href={b + '/platforma/teleradiologie/'}>{t.p4}</a>
          <a href={b + '/platforma/portal-pacient/'}>{t.p5}</a>
        </div>
      </div>
      <div class="drop">
        <button type="button" aria-expanded="false">{t.solutions} <span aria-hidden="true">▾</span></button>
        <div class="menu">
          <a href={b + '/solutii/clinici/'}>{t.s1}</a>
          <a href={b + '/solutii/spitale/'}>{t.s2}</a>
          <a href={b + '/solutii/teleradiologie/'}>{t.s3}</a>
        </div>
      </div>
      <a href={b + '/arhitectura/'}>{t.architecture}</a>
      <a href={b + '/noutati/'}>{t.news}</a>
    </nav>
    <div class="actions">
      <button type="button" class="icon-btn" id="theme-toggle" aria-label={t.theme}>◐</button>
      <a class="lang" href={altHref}>{t.langLabel}</a>
      <a class="btn btn-solid btn-sm" href={b + '/demo/'}>{t.demo}</a>
      <button type="button" class="icon-btn nav-burger" id="nav-toggle" aria-label="Meniu" aria-expanded="false">☰</button>
    </div>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--ink) 86%, transparent); backdrop-filter: blur(12px); border-bottom: 1px solid var(--line); }
  .bar { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding-top: 14px; padding-bottom: 14px; }
  .logo { font-size: 21px; font-weight: 800; color: var(--hi); letter-spacing: -0.01em; }
  .logo b { color: var(--blue-soft); }
  .nav { display: flex; align-items: center; gap: 26px; font-size: 15px; color: var(--mut); }
  .nav > a:hover { color: var(--hi); }
  .drop { position: relative; }
  .drop > button { background: none; border: 0; color: inherit; font-size: inherit; cursor: pointer; padding: 6px 0; }
  .drop > button:hover { color: var(--hi); }
  .menu { position: absolute; top: 100%; left: -14px; min-width: 230px; background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 8px; display: none; flex-direction: column; box-shadow: 0 18px 40px rgba(0,0,0,.35); }
  .menu a { padding: 9px 12px; border-radius: 8px; font-size: 14.5px; }
  .menu a:hover { background: var(--panel-2); color: var(--hi); }
  .drop:hover .menu, .drop:focus-within .menu, .drop.open .menu { display: flex; }
  .actions { display: flex; align-items: center; gap: 12px; }
  .icon-btn { background: none; border: 1px solid var(--line); border-radius: 10px; color: var(--mut); width: 36px; height: 36px; cursor: pointer; font-size: 15px; }
  .icon-btn:hover { color: var(--hi); border-color: var(--blue-dim); }
  .lang { font-size: 13.5px; font-weight: 700; color: var(--mut); border: 1px solid var(--line); border-radius: 10px; padding: 7px 11px; }
  .lang:hover { color: var(--hi); border-color: var(--blue-dim); }
  .btn-sm { padding: 9px 16px; font-size: 14px; }
  .nav-burger { display: none; }
  @media (max-width: 920px) {
    .nav { display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--panel); border-bottom: 1px solid var(--line); flex-direction: column; align-items: flex-start; padding: 16px 28px 22px; gap: 8px; }
    .nav.open { display: flex; }
    .menu { position: static; display: flex; border: 0; box-shadow: none; padding: 0 0 0 14px; background: transparent; }
    .drop > button { font-weight: 700; color: var(--hi); }
    .nav-burger { display: block; }
    .btn-sm { display: none; }
  }
</style>
